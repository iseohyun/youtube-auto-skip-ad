{
  "manifest_version": 3,
  "name": "YouTube Ad Full Watch",
  "version": "1.1-beta",
  "description": "유튜브 광고를 정속으로 완전히 봐주면서 귀찮은 건너뛰기 클릭만 인간다운 대기 시간 후에 대신해 줍니다.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
